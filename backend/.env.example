# Copy this file to .env and fill in the values


# Database
DATABASE_URL=postgresql+psycopg://username:password@localhost:5432/database_name

# Security
# Must be minimum 32 characters — never share this value
SECRET_KEY=

# JWT algorithm — do not change unless approved by team leader
ALGORITHM=HS256

# Token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application
# Options: development or production
ENVIRONMENT=development

# Adaptive Engine
# Score below this value → difficulty decreases
STUDENT_SCORE_THRESHOLD_LOW=

# Score above this value → difficulty increases
STUDENT_SCORE_THRESHOLD_HIGH=

# Formula version — sync with frontend/utils/constants.js SCORE_VERSION
SCORE_VERSION=

# File Upload 
# Maximum file size in megabytes
MAX_UPLOAD_SIZE_MB=